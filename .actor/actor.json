{
  "actorSpecification": 1,
  "name": "cardekho-cartrade-india-used-cars-scraper",
  "title": "CarDekho & CarTrade India Used Cars Scraper",
  "description": "Scrape Indian used-car listings from CarDekho and CarTrade with prices, model year, kilometres, fuel type, transmission, images, and listing URLs.",
  "version": "1.0",
  "buildTag": "latest",
  "meta": {
    "templateId": "ts-start"
  },
  "dockerfile": "Dockerfile",
  "input": "../INPUT_SCHEMA.json",
  "readme": "../README.md",
  "output": "./output_schema.json",
  "storages": {
    "dataset": "./dataset_schema.json"
  },
  "defaultRunOptions": {
    "build": "latest",
    "memoryMbytes": 4096,
    "timeoutSecs": 3600
  },
  "minMemoryMbytes": 4096,
  "maxMemoryMbytes": 4096,
  "categories": ["OTHER", "AUTOMATION"],
  "categoriesVersion": "1.0.0",
  "exampleRunInput": {
    "body": "{\"source\":\"cardekho\",\"cities\":[\"Mumbai\"],\"models\":[\"Honda City\"],\"maxResults\":1,\"proxyConfiguration\":{\"useApifyProxy\":false}}",
    "contentType": "application/json"
  },
  "pricingInfo": {
    "pricingModel": "PAY_PER_EVENT",
    "pricingPerEvent": {
      "actorChargeEvents": {
        "apify-actor-start": {
          "eventTitle": "Actor Start",
          "eventDescription": "Charged when the Actor starts. Number of events depends on memory (one per GB, minimum one).",
          "eventPriceUsd": 0.00005,
          "isPrimaryEvent": false,
          "isOneTimeEvent": true
        },
        "car-scraped": {
          "eventTitle": "Car scraped",
          "eventDescription": "Charged once for each clean used-car listing saved to the dataset.",
          "eventPriceUsd": 0.003,
          "isPrimaryEvent": true,
          "isOneTimeEvent": false
        }
      }
    }
  }
}
