{
    "title":  "India Used Cars Scraper Input",
    "description":  "Collect public used-car listings. For a low-cost first run, use CarDekho, Mumbai, Honda City, one result, no price filters, and direct requests.",
    "type":  "object",
    "schemaVersion":  1,
    "properties":  {
                       "source":  {
                                      "title":  "Source",
                                      "type":  "string",
                                      "description":  "Choose one marketplace or both. Start with CarDekho for the smallest first run.",
                                      "editor":  "select",
                                      "default":  "cardekho",
                                      "enum":  [
                                                   "both",
                                                   "cardekho",
                                                   "cartrade"
                                               ],
                                      "enumTitles":  [
                                                         "Both",
                                                         "CarDekho",
                                                         "CarTrade"
                                                     ]
                                  },
                       "cities":  {
                                      "title":  "Cities",
                                      "type":  "array",
                                      "description":  "Indian cities to search. Start with one city such as Mumbai, Delhi NCR, Bangalore, Hyderabad, Chennai, or Pune.",
                                      "editor":  "stringList",
                                      "minItems":  1,
                                      "maxItems":  10,
                                      "default":  [
                                                      "Mumbai"
                                                  ]
                                  },
                       "models":  {
                                      "title":  "Car models",
                                      "type":  "array",
                                      "description":  "Car make/model searches. Start with one model such as Honda City, Maruti Swift, or Toyota Fortuner. Use All Cars for broad city listings.",
                                      "editor":  "stringList",
                                      "minItems":  1,
                                      "maxItems":  10,
                                      "default":  [
                                                      "Honda City"
                                                  ]
                                  },
                       "minPrice":  {
                                        "title":  "Minimum price",
                                        "type":  "integer",
                                        "description":  "Optional minimum used-car price in INR.",
                                        "editor":  "number",
                                        "minimum":  0
                                    },
                       "maxPrice":  {
                                        "title":  "Maximum price",
                                        "type":  "integer",
                                        "description":  "Optional maximum used-car price in INR.",
                                        "editor":  "number",
                                        "minimum":  0
                                    },
                       "maxResults":  {
                                          "title":  "Max results",
                                          "type":  "integer",
                                          "description":  "Maximum number of unique used-car listings to save. Start with 1, inspect the output, and then scale up.",
                                          "editor":  "number",
                                          "default":  1,
                                          "minimum":  1,
                                          "maximum":  500
                                      },
                       "proxyConfiguration":  {
                                                  "title":  "Proxy configuration",
                                                  "type":  "object",
                                                  "description":  "Direct requests are the low-cost default. Enable Apify Proxy only when source access is unreliable.",
                                                  "editor":  "proxy",
                                                  "default":  {
                                                                  "useApifyProxy":  false
                                                              }
                                              }
                   },
    "required":  [
                     "source",
                     "cities",
                     "models",
                     "maxResults"
                 ]
}
