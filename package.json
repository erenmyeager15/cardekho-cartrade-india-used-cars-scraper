{
  "name": "cardekho-cartrade-india-used-cars-scraper",
  "version": "1.0.0",
  "description": "Apify Actor for scraping India used-car listings from CarDekho and CarTrade.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc",
    "start": "node dist/main.js",
    "lint": "node ./node_modules/typescript/bin/tsc --noEmit",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "test": "npm run build && node --test dist/billing.test.js dist/routes.test.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "apify": "^3.4.2",
    "undici": "^6.21.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "typescript": "^5.5.4"
  }
}
